generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())

  username     String   @unique
  email        String   @unique
  password      String

  reviews      Review[]
  lists        GameList[]

  addedGames   Game[] @relation("GameCreator")

  createdAt    DateTime @default(now())
}

model Game {
  id            String   @id @default(cuid())

  title         String
  slug          String   @unique

  description   String

  image         String
  cover         String
  esrb          String?
  modes         String[] @default([])

  releaseDate   DateTime

  developer     String[] @default([])
  publisher     String[] @default([])
  screenshots   String[] @default([])

  platforms     String[]
  genres        String[]

  addedById     String
  addedBy       User @relation("GameCreator", fields: [addedById], references: [id])

  reviews       Review[]
  userLists     GameList[]

  createdAt     DateTime @default(now())
}

model Review {
  id          String   @id @default(cuid())

  rating      Int
  content     String

  userId      String
  gameId      String

  user        User @relation(fields: [userId], references: [id])
  game        Game @relation(fields: [gameId], references: [id])

  createdAt   DateTime @default(now())
}

model GameList {
  id          String   @id @default(cuid())

  status      GameStatus

  userId      String
  gameId      String

  user        User @relation(fields: [userId], references: [id])
  game        Game @relation(fields: [gameId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([userId, gameId])
}

enum GameStatus {
  WANT_TO_PLAY
  PLAYING
  COMPLETED
}